{
  "name": "@neerav34/env-doctor",
  "version": "1.0.1",
  "description": "The eslint of environment variables — catch missing env vars before they hit production",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "env-doctor": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "dogfood": "node ./dist/index.js check --strict --ignore 'tests/**' '**/*.md' '**/*.d.ts'",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "tsx": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "env",
    "environment",
    "variables",
    "dotenv",
    "cli",
    "developer-tools",
    "ci",
    "devops",
    "lint",
    "security"
  ],
  "license": "MIT",
  "author": "Neerav Jha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neerav34/env-doctor.git"
  },
  "homepage": "https://github.com/neerav34/env-doctor#readme",
  "bugs": {
    "url": "https://github.com/neerav34/env-doctor/issues"
  },
  "type": "module"
}
